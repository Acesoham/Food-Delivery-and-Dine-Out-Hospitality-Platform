# ===== MongoDB =====
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/food-delivery?retryWrites=true&w=majority

# ===== JWT =====
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ===== Stripe =====
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# ===== AWS S3 =====
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_S3_BUCKET=food-delivery-uploads
AWS_REGION=ap-south-1

# ===== Redis =====
REDIS_URL=redis://localhost:6379

# ===== Server =====
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
MERCHANT_URL=http://localhost:5174

# ===== Gemini API (Optional - for AI review prompts) =====
GEMINI_API_KEY=your-gemini-api-key
